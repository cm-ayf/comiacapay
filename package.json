    "drizzle-kit": "1.0.0-rc.2",
    "eslint-plugin-mui-path-imports": "0.0.15",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.22.1",
    "vite": "8.0.10",
    "vite-plugin-pwa": "1.2.0"
