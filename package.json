{
  "name": "comiacapay",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "run-p postinstall:*",
    "postinstall:react-router-typegen": "react-router typegen",
    "prepare": "node .husky/install.js",
    "build": "react-router build --sourcemapServer",
    "preview": "vite preview",
    "dev": "react-router dev",
    "check:tsgo": "tsgo",
    "check:oxlint": "oxlint --type-aware .",
    "check:oxfmt": "oxfmt --check .",
    "check": "run-p check:*",
    "fix:oxlint": "oxlint --fix",
    "fix:oxfmt": "oxfmt --write .",
    "fix": "run-s fix:*",
    "migrate:generate": "drizzle-kit generate",
    "migrate:deploy": "drizzle-kit migrate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@conform-to/react": "1.19.1",
