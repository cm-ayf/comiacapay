    "@mui/lab": "9.0.0-beta.2",
    "@mui/material": "9.0.0",
    "@mui/x-charts": "9.1.0",
    "@mui/x-data-grid": "9.1.0",
    "@react-router/fs-routes": "7.14.2",
    "@react-router/node": "7.14.2",
    "discord-api-types": "0.38.47",
    "drizzle-orm": "1.0.0-rc.2",
    "idb": "^8.0.3",
    "isbot": "5.1.40",
    "postgres": "3.4.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.14.2",
    "valibot": "1.4.0"
  },
  "devDependencies": {
    "@oxlint/plugins": "1.62.0",
    "@playwright/test": "1.57.0",
    "@react-router/dev": "7.14.2",
